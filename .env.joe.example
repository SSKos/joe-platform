# JOE — production environment variables
# Copy this file: cp .env.joe.example .env.joe
# Fill in real values. NEVER commit .env.joe to git.

# ── Server ────────────────────────────────────────────────────────────────────

# Port the Express app listens on inside the container.
# Must match the port in joe-docker-compose.prod.yml and Dockerfile EXPOSE.
PORT=3000

# Set to production — enables static file serving and correct cookie flags.
NODE_ENV=production

# ── Authentication ────────────────────────────────────────────────────────────

# Secret key used to sign and verify JWT tokens.
# Generate a strong value: openssl rand -hex 32
# If this changes, all existing sessions are invalidated.
JWT_SECRET=replace_with_a_long_random_string_minimum_32_characters

# How long a JWT token remains valid. Examples: 7d, 24h, 30d
JWT_EXPIRY=7d

# ── Database ──────────────────────────────────────────────────────────────────

# MongoDB connection string.
# IMPORTANT: Use the Docker service name 'joe_mongo' as the hostname, NOT localhost.
# Inside Docker, containers communicate by service name via Docker's internal DNS.
# 'localhost' inside the joe_backend container refers to that container itself,
# not the MongoDB container — the connection would fail.
MONGODB_URI=mongodb://joe_mongo:27017/JOEdb

# ── CORS ──────────────────────────────────────────────────────────────────────

# The exact origin from which the browser sends requests to the API.
# Must match the URL users see in their browser (including https://).
# In production this is the subdomain where JOE is served.
ALLOWED_ORIGIN=https://joe.kk-about.me
