# ─── Server ──────────────────────────────────────────────────────────────────
PORT=2000
NODE_ENV=development

# ─── Authentication ──────────────────────────────────────────────────────────
# Required. Use a long random string in production (e.g. openssl rand -hex 64).
JWT_SECRET=
JWT_EXPIRY=7d

# ─── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/JOEdb

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Set to the deployed frontend URL in production.
ALLOWED_ORIGIN=http://localhost:3000

# ─── File storage (Phase 2 — replace local disk with S3) ─────────────────────
# AWS_REGION=
# AWS_BUCKET_NAME=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ─── Redis (Phase 2 — caching, job queue) ─────────────────────────────────────
# REDIS_URL=redis://localhost:6379

# ─── Email (Phase 2 — editorial workflow notifications) ──────────────────────
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# ─── Payments (Phase 2 — reviewer compensation) ──────────────────────────────
# STRIPE_SECRET_KEY=

# ─── External services (Phase 2) ─────────────────────────────────────────────
# ORCID_CLIENT_ID=
# ORCID_CLIENT_SECRET=
# ITHENTICATE_API_KEY=
# CROSSREF_API_KEY=
